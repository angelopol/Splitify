generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  splitRuns     SplitRun[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SplitRun {
  id                 String            @id @default(cuid())
  userId             String
  sourcePlaylistId   String
  sourcePlaylistName String
  prompt             String?
  mode               String
  duplicatePolicy    String
  playlistPrefix     String            @default("Splitify - ")
  visibility         String            @default("private")
  status             String            @default("draft")
  error              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  categories         SplitCategory[]
  assignments        SplitAssignment[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SplitCategory {
  id                String            @id @default(cuid())
  splitRunId        String
  name              String
  description       String?
  order             Int
  spotifyPlaylistId String?
  spotifyUrl        String?
  assignments       SplitAssignment[]

  splitRun SplitRun @relation(fields: [splitRunId], references: [id], onDelete: Cascade)

  @@index([splitRunId, order])
}

model SplitAssignment {
  id            String @id @default(cuid())
  splitRunId    String
  categoryId    String
  trackId       String
  trackUri      String
  trackName     String
  artists       String
  album         String?
  durationMs    Int?
  sourceOrder   Int
  categoryOrder Int
  trackMetadata String

  splitRun SplitRun      @relation(fields: [splitRunId], references: [id], onDelete: Cascade)
  category SplitCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([splitRunId, sourceOrder])
  @@index([categoryId, categoryOrder])
}
